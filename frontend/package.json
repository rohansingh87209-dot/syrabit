    "ajv": "^8.17.1",
    "axios": "^1.8.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.4",
    "lucide-react": "^0.507.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "1.3.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.5.1",

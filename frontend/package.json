  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "test": "craco test",
    "build:prod": "GENERATE_SOURCEMAP=false DISABLE_ESLINT_PLUGIN=true react-scripts build",
    "analyze": "npm run build:prod && npx source-map-explorer \"build/static/js/*.js\" --html build/bundle-analysis.html",
    "lighthouse": "npx lhci autorun --config=./lighthouserc.json 2>/dev/null || npx lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json --chrome-flags=\"--headless\"",
    "quality": "npm run build:prod && echo \"Bundle: OK\" && npm run lighthouse 2>/dev/null || echo \"Quality check complete\"",
    "serve:prod": "npx serve -s build -l 3001"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@craco/craco": "^7.1.0",
    "@eslint/js": "9.23.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "15.15.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "overrides": {
    "nth-check": ">=2.0.1",
    "serialize-javascript": ">=7.0.3",
    "underscore": ">=1.13.8"
  }
}
